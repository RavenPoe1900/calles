      "name": "Plaza de Armas, La Habana Vieja",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/entrecalles?lat=23.14022&lon=-82.34938&radio_m=100",
          "host": ["{{baseUrl}}"],
          "path": ["entrecalles"],
          "query": [
            {
              "key": "lat",
              "value": "23.14022",
              "description": "Latitud"
            },
            {
              "key": "lon",
              "value": "-82.34938",
              "description": "Longitud"
            },
            {
              "key": "radio_m",
              "value": "100",
              "description": "Radio de búsqueda en metros"
            }
          ]
        },
        "description": "Ubicación histórica en el corazón de La Habana Vieja, rodeada de calles coloniales."
      },
      "response": [
        {
          "name": "200 OK",
          "originalRequest": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/entrecalles?lat=23.14022&lon=-82.34938&radio_m=100",
              "host": ["{{baseUrl}}"],
              "path": ["entrecalles"],
              "query": [
                { "key": "lat", "value": "23.14022" },
                { "key": "lon", "value": "-82.34938" },
                { "key": "radio_m", "value": "100" }
              ]
            }
          },
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"direccion\": \"Plaza de Armas, Baratillo, Catedral, La Habana Vieja, La Habana, Cuba\",\n  \"calle_principal\": \"Baratillo\",\n  \"entrecalles\": [\"Enna\", \"Narciso López\", \"O'Reilly\", \"Obispo\", \"Oficios\", \"Tacón\"],\n  \"lat\": 23.14022,\n  \"lon\": -82.34938\n}"
